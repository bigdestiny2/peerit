# Copy to .env and fill in. Do NOT commit .env.

# Public domain that resolves (A/AAAA) to this VPS. Caddy provisions a TLS cert for
# it, and browsers connect to wss://<this-domain>. e.g. dht.peerit.example
DHT_RELAY_DOMAIN=dht.example.com

# Email Let's Encrypt uses for cert-expiry notices.
ACME_EMAIL=you@example.com
