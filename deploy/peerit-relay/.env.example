# Copy to .env and fill in. Do NOT commit .env.

# The TLS hostname Caddy provisions a cert for. sslip.io needs no domain purchase:
# <dashed-ip>.sslip.io resolves to that IP. This must match the relay URL you put
# (as relay #1) in peerit's deploy/web-release.json + signed relay-roster.json.
RELAY_DOMAIN=153-75-89-206.sslip.io

# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=acme@example.com

# The web origin peerit is served from (CORS allowlist). Comma-separate if several.
PEERIT_RELAY_ORIGINS=https://peerit.site

# HMAC secret for issued tokens. MUST be stable across restarts (else all testers
# are logged out) and secret. Generate once:  openssl rand -hex 32
PEERIT_RELAY_SECRET=CHANGE_ME_openssl_rand_hex_32
