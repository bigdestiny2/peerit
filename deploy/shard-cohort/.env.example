# Public shard-store relay configuration.
# Copy to .env and fill in real values before `docker compose up -d`.

# Public domain or sslip.io address for this relay.
RELAY_DOMAIN=shard-a.example.com

# 32-byte hex API key. Keep secret — the peerit dealer uses this to PUT shards.
# Generate: openssl rand -hex 32
RELAY_API_KEY=

# Origin allowed to fetch shards from a browser (CORS). Use the peerit site origin.
PEERIT_ORIGIN=https://peerit.site

# Internal API port. Caddy forwards public HTTPS traffic here.
HIVERELAY_API_PORT=9100

# Persistent host directory for relay storage.
HIVERELAY_STORAGE=./data

# 0-based index for this relay (used to keep multiple relays on one host apart).
RELAY_INDEX=0
